{
  "$schema": "https://biomejs.dev/schemas/2.0.6/schema.json",
  "root": true,

  "files": {
    "includes": ["**/*", "!.pnp.cjs", "!.pnp.loader.mjs", "!**/dist"]
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": "info",
      "suspicious": {
        "noArrayIndexKey": "off"
      }
    }
  },

  "formatter": {
    "lineWidth": 100,
    "indentStyle": "space",
    "indentWidth": 2,
    "bracketSpacing": true,
    "attributePosition": "multiline",
    "expand": "auto"
  },

  "javascript": {
    "parser": {
      "jsxEverywhere": true
    },
    "jsxRuntime": "transparent",
    "formatter": {
      "enabled": true,
      "lineWidth": 100,
      "indentStyle": "space",
      "indentWidth": 2,
      "bracketSpacing": true,
      "attributePosition": "multiline",
      "arrowParentheses": "asNeeded",
      "expand": "auto",
      "bracketSameLine": true
    },
    "linter": {
      "enabled": true
    }
  },

  "json": {
    "parser": {
      "allowComments": true
    },
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 100,
      "trailingCommas": "none"
    },
    "linter": {
      "enabled": true
    }
  }
}
